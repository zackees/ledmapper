.aider*
.env

!.aider.conf.yml
!.aiderignore

.certs/
node_modules/
dist/
test-results/
playwright-report/
playwright/.cache/
tests/canvas-fit/output/
tests/perf/output/
tests/ux/out/

.claude/worktrees/
.claude/projects/
.claude/snapshots/
.claude/snapshots-after/
.claude/snapshots-3mode/
.claude/*.mjs
.claude/*.md
.claude/ts-mig-tmp/

# Sibling extern checkouts (e.g. fastled) — convention from
# the clud-extern-repos workflow; never part of this repo's history.
/.extern-repos/

# agent-browser persistent session/profile state — can contain auth
# tokens and cookies; never part of this repo's history (issue #320).
.agent-ui/
.agent-browser/
.auth/
*.browser-state.json

# Scratch verification-run logs (this session's manual test output).
.temp/logs/*.log
