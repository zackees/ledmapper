{
  "name": "@fastled/gfx",
  "version": "0.1.0",
  "description": "FastLED-compatible LED renderer (Three.js + UnrealBloom). Shared by FastLED wasm-compiler and ledmapper.com. See https://github.com/zackees/ledmapper.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "core": ["core.d.ts"],
      "fled": ["fled.d.ts"],
      "worker": ["worker.d.ts"]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./fled": {
      "types": "./dist/fled.d.ts",
      "import": "./dist/fled.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "core.js",
    "core.d.ts",
    "fled.js",
    "fled.d.ts",
    "worker.js",
    "worker.d.ts"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "three": ">=0.170 <0.190"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zackees/ledmapper.git",
    "directory": "packages/gfx"
  },
  "homepage": "https://github.com/zackees/ledmapper/tree/main/packages/gfx",
  "bugs": {
    "url": "https://github.com/zackees/ledmapper/issues"
  },
  "keywords": [
    "fastled",
    "led",
    "renderer",
    "three.js",
    "webgl",
    "bloom"
  ],
  "publishConfig": {
    "access": "public"
  }
}
