    "../../src/three-bloom.ts",
    "../../src/ui/sliders.ts",
    "../../src/ui/signal.ts",
    "../../src/render/bloom-geometry.ts",
    "../../src/render/bloom-ui.ts",
    "../../src/render/rgb-video.ts",
    "../../src/types/domain.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
