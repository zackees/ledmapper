  },
  "homepage": "https://github.com/zackees/ledmapper#readme",
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "sweetalert2": "^11.26.21",
    "tailwindcss": "^4.2.2",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.9.3",
    "@types/three": "^0.184.1",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "tsx": "^4.22.4",
